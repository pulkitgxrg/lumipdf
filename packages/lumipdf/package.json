{
  "name": "lumipdf",
  "version": "1.0.0",
  "description": "a react based pdf viewer library based on pdf.js",
  "type": "module",
  "scripts": {
    "build": "tsc && mkdir -p dist/styles && cp src/styles/index.css dist/styles/index.css",
    "check-types": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles": "./src/styles/index.css"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pulkitgarg04/lumipdf.git",
    "directory": "packages/lumipdf"
  },
  "author": "Pulkit Garg",
  "peerDependencies": {
    "pdfjs-dist": "^4.7",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "pdfjs-dist": {
      "optional": true
    }
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.10",
    "comlink": "^4.4.2",
    "vite": "^8.1.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.0",
    "@types/react-dom": "^19.0",
    "pdfjs-dist": "^4.7",
    "react": "^19.0",
    "react-dom": "^19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "react",
    "pdf",
    "document-viewer",
    "doc-viewer",
    "viewer",
    "document",
    "file-viewer",
    "pdfjs",
    "react-component"
  ],
  "license": "MIT"
}
